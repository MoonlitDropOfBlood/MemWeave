{
  "name": "memweave",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run web:build && tsx src/server/bootstrap.ts",
    "web:dev": "cd web && npm run dev",
    "web:build": "cd web && npm run build",
    "mcp": "tsx src/mcp/index.ts",
    "cli": "tsx src/cli-entry.ts",
    "build": "npm run web:build && tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "bin": {
    "memweave": "./dist/src/cli-entry.js",
    "memweave-mcp": "./dist/src/mcp/index.js"
  },
  "dependencies": {
    "@fastify/cors": "11.2.0",
    "@fastify/static": "^9.1.3",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "12.10.0",
    "fastify": "5.8.5",
    "jsonc-parser": "3.3.1",
    "pino": "10.3.1",
    "sqlite-vec": "^0.1.9",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.17.3",
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "25.9.2",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  }
}
