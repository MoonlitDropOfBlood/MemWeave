{
  "name": "memweave",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Root workspace for the @mem-weave/* monorepo. The three published packages live in packages/ — see packages/<name>/package.json. This file only exists to orchestrate dev/test/build/publish across them.",
  "scripts": {
    "dev": "npm run web:build && tsx packages/server/src/server/bootstrap.ts",
    "web:dev": "cd web && npm run dev",
    "web:build": "cd web && npm run build",
    "web:sync": "node scripts/sync-web-dist.cjs",
    "build:server": "cd packages/server && npm run build",
    "build:opencode-plugin": "cd packages/opencode-plugin && npm run build",
    "build": "npm run web:build && npm run build:server && npm run build:opencode-plugin && npm run web:sync",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "publish:dry-run": "node scripts/publish.mjs --dry-run",
    "publish": "node scripts/publish.mjs --publish"
  },
  "bin": {
    "memweave": "./packages/server/dist/cli-entry.js"
  },
  "onlyBuiltDependencies": [
    "better-sqlite3",
    "sharp",
    "protobufjs"
  ],
  "dependencies": {
    "@fastify/cors": "11.2.0",
    "@fastify/static": "^9.1.3",
    "better-sqlite3": "12.10.0",
    "fastify": "5.8.5",
    "jsonc-parser": "3.3.1",
    "pino": "10.3.1",
    "sqlite-vec": "^0.1.9",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.17.3",
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "25.9.2",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  }
}
