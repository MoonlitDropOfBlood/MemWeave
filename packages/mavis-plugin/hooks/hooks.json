{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$PLUGIN_DIR/hooks/prompt-inject.sh",
            "commandWindows": "$PLUGIN_DIR\\hooks\\prompt-inject.cmd",
            "timeout": 15,
            "statusMessage": "MemWeave: injecting relevant memories"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Read|Edit|Write|Glob|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "$PLUGIN_DIR/hooks/file-pack.sh",
            "commandWindows": "$PLUGIN_DIR\\hooks\\file-pack.cmd",
            "timeout": 10,
            "statusMessage": "MemWeave: file-scoped memories"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$PLUGIN_DIR/hooks/writeback.sh",
            "commandWindows": "$PLUGIN_DIR\\hooks\\writeback.cmd",
            "timeout": 30,
            "statusMessage": "MemWeave: writing session to memory"
          }
        ]
      }
    ]
  }
}
